# Copy this file to `.env` and fill in values.

# Braintrust: https://www.braintrust.dev/app/settings?subroute=api-keys
BRAINTRUST_API_KEY=

# Optional: logs go to this project (created automatically if missing)
BRAINTRUST_PROJECT_NAME=ISYS398U-ParalegalDemo

# OpenAI: https://platform.openai.com/api-keys
# You can instead add the key only in Braintrust "AI providers" and use the proxy;
# this demo passes the key to the OpenAI SDK directly.
OPENAI_API_KEY=

# Optional: dataset name for /capture rows (default: live-captures)
# BRAINTRUST_CAPTURE_DATASET=live-captures

